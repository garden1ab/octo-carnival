# ============================================================
#  .env.example — copy to .env and fill in your values
# ============================================================

# ── Server ──────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ── Document handling ───────────────────────────────────────
UPLOAD_DIR=./uploads
CHUNK_SIZE=3000
CHUNK_OVERLAP=200
MAX_CONCURRENT_AGENTS=5

# ── Controller LLM ──────────────────────────────────────────
# Provider: anthropic | openai | openai_compat | local
CONTROLLER_PROVIDER=anthropic
CONTROLLER_MODEL=claude-sonnet-4-20250514
CONTROLLER_MAX_TOKENS=4096
CONTROLLER_TEMPERATURE=0.3
CONTROLLER_TIMEOUT=120
CONTROLLER_MAX_RETRIES=3

# ── Shared API keys (used when no per-agent key is set) ─────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
# OPENAI_COMPAT_API_KEY=        # for OpenAI-compatible endpoints

# ── Worker Agents ───────────────────────────────────────────
# Define agents with numbered prefixes: AGENT_1_, AGENT_2_, …
# Supported providers: anthropic | openai | openai_compat | local

# Agent 1 — Anthropic Haiku (fast, cheap)
AGENT_1_ID=researcher
AGENT_1_PROVIDER=anthropic
AGENT_1_MODEL=claude-haiku-4-5-20251001
AGENT_1_MAX_TOKENS=2048
AGENT_1_TEMPERATURE=0.5

# Agent 2 — OpenAI GPT-4o-mini
AGENT_2_ID=analyst
AGENT_2_PROVIDER=openai
AGENT_2_MODEL=gpt-4o-mini
AGENT_2_MAX_TOKENS=2048
AGENT_2_TEMPERATURE=0.7

# Agent 3 — Local Ollama (no API key needed)
# AGENT_3_ID=local-writer
# AGENT_3_PROVIDER=local
# AGENT_3_MODEL=llama3
# AGENT_3_BASE_URL=http://host.docker.internal:11434/v1
# AGENT_3_MAX_TOKENS=2048

# Agent 4 — Custom OpenAI-compatible endpoint
# AGENT_4_ID=custom-agent
# AGENT_4_PROVIDER=openai_compat
# AGENT_4_MODEL=my-fine-tuned-model
# AGENT_4_BASE_URL=https://my-custom-api.example.com/v1
# AGENT_4_API_KEY=my-secret-key
